                                       INPUT FILE
================================================================================
NAME = methane.inp
|  1> # CH4: CCSD(T) geometry optimization + freq. calc. at the final geom.
|  2> #      Basis: aug-cc-pVTZ
|  3> #      CCSD : Frozen core
|  4> 
|  5> # Set the base name for the output file
|  6> %base "CH4_CCSD"
|  7> 
|  8> %pal
|  9>     nprocs 8     
| 10> end
| 11> 
| 12> # Keyword line
| 13> ! CCSD(T) Opt NumGrad NumFreq
| 14> 
| 15> # Output
| 16> %output
| 17>   PrintLevel  3
| 18> end
| 19> 
| 20> # Basis
| 21> %basis
| 22>   Basis  "aug-cc-pVTZ"
| 23> end
| 24> 
| 25> # SCF block
| 26> %scf
| 27>   TolE   1e-12        
| 28>   MaxIter 200         
| 29>   Thresh 1e-18        
| 30>   TCut   1e-20        
| 31>   ConvCheckMode 2     
| 32> end
| 33> 
| 34> # Canonical Correlation Block
| 35> %mdci
| 36>   STol    1e-10       
| 37>   Triples 1           
| 38>   MaxIter 100         
| 39> end
| 40> 
| 41> %geom
| 42>       MaxIter 100 
| 43> 
| 44>       # Convergence 
| 45>       TolE 1.E-10
| 46>       TolRMSG  1.0E-6
| 47>       TolMAXG  3.0E-6
| 48>       TolRMSD  2.0E-5
| 49>       TolMaxD  4.0E-5
| 50> end
| 51> 
| 52> 
| 53> # Coordinate block (Default: Angstroem)
| 54> * xyz 0 1          # Charge:0  Spin:2S+1
