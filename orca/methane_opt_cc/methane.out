|  7> 
|  8> %pal
|  9>     nprocs 8     
| 10> end
| 11> 
| 12> # Keyword line
| 13> ! CCSD(T) Opt NumGrad NumFreq
| 14> 
| 15> # Output
| 16> %output
| 17>   PrintLevel  3
| 18> end
| 19> 
| 20> # Basis
| 21> %basis
| 22>   Basis  "aug-cc-pVTZ"
| 23> end
| 24> 
| 25> # SCF block
| 26> %scf
| 27>   TolE   1e-12        
| 28>   MaxIter 200         
| 29>   Thresh 1e-18        
