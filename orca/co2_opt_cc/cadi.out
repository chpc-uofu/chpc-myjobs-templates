                                       INPUT FILE
================================================================================
NAME = cadi.inp
|  1> # CO2: CCSD(T) geometry optimization + freq calc at CCSD(T) level
|  2> #      Basis: aug-cc-pVQZ
|  3> 
|  4> # Set the base name for the output file
|  5> %base "CO2-CC_"
|  6> 
|  7> %pal
|  8>     nprocs 16
|  9> end
| 10> 
| 11> # Keyword line
| 12> ! CCSD(T) Opt NumGrad NumFreq
| 13> 
| 14> # Output
| 15> %output
| 16>   PrintLevel  3
| 17> end
| 18> 
| 19> # Basis
| 20> %basis
| 21>   Basis  "aug-cc-pVTZ"
| 22> end
| 23> 
| 24> # SCF Block
| 25> %scf
| 26>   MaxIter 200
| 27>   TolE   1.0e-12      # SCF energy change threshold
| 28>   Thresh 1.0e-18      # integral prescreening threshold
| 29>   TCut   1.0e-20      # primitive integral prescreening cutoff
| 30>   ConvCheckMode 2     # default-style convergence check (energy-based)
| 31> end
| 32> 
| 33> # Canonical correlation Block
| 34> %mdci
| 35>   MaxIter 100         # Max. CC Iterations
| 36>   STol    1.0e-10     # tighten CC residual convergence (stricter than default)
| 37>   Triples 1           # Request the (T) correction
| 38> end
| 39> 
| 40> %coords
| 41>   CTyp internal
| 42>   Charge 0
| 43>   Mult 1
| 44>   # Define your variables here
| 45>   pardef 
| 46>     R1 = 1.16; 
| 47>   end
| 48>   # Z-matrix: AtomN NA NB NC  {Bond} {Angle} {Dihedral}
| 49>   coords
| 50>     O  0  0  0    0.0    0.0    0.0
| 51>     C  1  0  0    {R1}   0.0    0.0
| 52>     O  2  1  0    {R1}   180.0  0.0
| 53>   end
| 54> end
| 55> 
| 56> %geom
| 57>       MaxIter 100
| 58> 
| 59>       # Convergence 
| 60>       TolE 1.E-10
| 61>       TolRMSG  1.0E-6
| 62>       TolMAXG  3.0E-6
| 63>       TolRMSD  2.0E-5
| 64>       TolMaxD  4.0E-5
| 65> end
| 66> 
| 67> 
| 68> 
| 69> 
| 70>                          ****END OF INPUT****
