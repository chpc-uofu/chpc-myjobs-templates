                                       INPUT FILE
================================================================================
NAME = water.inp
|  1> # Water: CCSD(T) - calculate freq.
|  2> #      Basis: aug-cc-pVQZ
|  3> 
|  4> # Set the base name for the output file
|  5> %pal
|  6>     nprocs 8     
|  7> end
|  8> 
|  9> # Keyword line
| 10> ! CCSD(T) RHF NumFreq
| 11> 
| 12> # Output
| 13> %output
| 14>   PrintLevel  3
| 15> end
| 16> 
| 17> # Basis
| 18> %basis
| 19>   Basis  "aug-cc-pVQZ"
| 20> end
| 21> 
| 22> # SCF block
| 23> %scf
| 24>   TolE   1e-12
| 25>   MaxIter 200
| 26>   Thresh 1e-18
| 27>   TCut   1e-20
| 28>   ConvCheckMode 2
| 29> end
| 30> 
| 31> # Canonical Correlation Block
| 32> %mdci
| 33>   STol    1e-10
| 34>   Triples 1
| 35>   MaxIter 100
| 36> end
| 37> 
| 38> 
| 39> # Coordinate block (Default: Angstroem)
| 40> * xyz 0 1          # Charge:0  Spin:2S+1
| 41> O  0.000000   0.000000   0.000000
| 42> H  0.000000   0.757000   0.587000
| 43> H  0.000000  -0.757000   0.587000
| 44> *
| 45> 
| 46> 
